include CHANGELOG.md
include CONTRIBUTING.md
include LICENSE
include README.md
include SKILL.md
include .env.example
include pyproject.toml
include requirements.txt
include docs/ADVISORY_SECRET_HANDLING.md
include docs/ADVISORY_RUNTIME.md
include docs/API_CONTRACT.md
include docs/EXAMPLE_AUDITS.md
include docs/MICA_MEMORY.md
include docs/SCORING_RATIONALE.md
include memory/mica.yaml
include memory/stem-ai.mica.v1.5.9.json
include memory/stem-ai-playbook.v1.5.9.md
include memory/stem-ai-lessons.v1.5.9.md

recursive-include stem_ai *.py
recursive-include tests *.py

prune .git
prune .github
prune .pytest_cache
prune __pycache__
prune audits
prune build
prune dist
prune tmp
prune stem_output*
prune stem_ai.egg-info

global-exclude *.py[cod]
global-exclude __pycache__
