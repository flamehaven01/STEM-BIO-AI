{
  "mica_spec": "0.2.0",
  "mica_schema_version": "0.2.0",
  "project": {
    "name": "STEM-BIO-AI",
    "full_name": "STEM BIO-AI: Deterministic Evidence-Surface Scanner for Bio/Medical AI Repositories",
    "version": "1.5.1",
    "status": "active",
    "purpose": "Deterministic local evidence-surface scanning for bio/medical AI repositories. Produces reproducible T0-T4 review-priority tiers from observable repository signals, plus separate replication, reasoning, and provider-advisory validation surfaces.",
    "canonical_statement": "STEM BIO-AI is a local deterministic evidence-surface scanner for bio/medical AI repositories. It scans README/docs/package/code surfaces, dependency hygiene, CI/test signals, AST-observable code structure, replication evidence, and license/use-scope boundaries. It reports T0-T4 review-priority tiers, a separate Stage 4 replication lane, diagnostic reasoning-model signals, and provider-neutral advisory packet/response validation. It does not certify clinical safety, regulatory compliance, model efficacy, scientific validity, or author intent; AI advisory output must cite exact evidence-ledger finding IDs and may not override deterministic scores."
  },
  "design_invariants": [
    {
      "id": "INV-001",
      "label": "stage-order-fixed",
      "statement": "Base-score evaluation order is fixed: Stage 1 (README Evidence) -> Stage 2R (Repo-Local Consistency) -> Stage 3 (Code/Bio Responsibility). Stage 4 replication evidence is reported after base scoring as a separate lane and may not be folded into final score without a minor-version rationale.",
      "severity": "critical"
    },
    {
      "id": "INV-002",
      "label": "weighted-formula-fixed",
      "statement": "Weighted average formula is fixed: S1 x 0.40, S2 x 0.20, S3 x 0.40. Weight values are IMMUTABLE.",
      "severity": "critical"
    },
    {
      "id": "INV-003",
      "label": "tier-boundaries-fixed",
      "statement": "Tier boundaries: T0(0-39), T1(40-54), T2(55-69), T3(70-84), T4(85-100). Boundaries are IMMUTABLE.",
      "severity": "critical"
    },
    {
      "id": "INV-004",
      "label": "t0-hard-floor",
      "statement": "T0_HARD_FLOOR: CA-DIRECT classification + zero code presence = T0 regardless of stage scores. No override. No exception.",
      "severity": "critical"
    },
    {
      "id": "INV-005",
      "label": "risk-penalty-checklist",
      "statement": "Risk penalties RP1(-15), RP2(-10), RP3(-10) are applied before tier assignment. Skipping any applicable penalty is a scoring error.",
      "severity": "critical"
    },
    {
      "id": "INV-006",
      "label": "na-redistribution",
      "statement": "When a stage returns N/A, its weight redistributes proportionally to remaining stages. N/A is never treated as 0.",
      "severity": "critical"
    },
    {
      "id": "INV-007",
      "label": "cross-llm-consistency-target",
      "statement": "Deterministic local scanner output should be reproducible for identical repository input. Provider advisory output is non-authoritative and may not modify score or tier.",
      "severity": "high"
    },
    {
      "id": "INV-008",
      "label": "anti-abuse-controls",
      "statement": "Anti-abuse: max 10 repos/session, no bulk sweeps, no individual profiling, no competitor analysis. Public repos only.",
      "severity": "critical"
    },
    {
      "id": "INV-009",
      "label": "mandatory-disclaimer-block",
      "statement": "Measurement-boundary disclaimer must appear in audit outputs. The scanner is a pre-screening evidence-surface tool, not certification, regulatory clearance, or medical advice.",
      "severity": "critical"
    },
    {
      "id": "INV-010",
      "label": "self-validation-gate-19-checks",
      "statement": "Release validation and regression checks must pass before publishing outputs as a versioned release artifact.",
      "severity": "critical"
    },
    {
      "id": "INV-011",
      "label": "ca-flag-three-tier",
      "statement": "Clinical adjacency flag is 3-tier: CA-DIRECT (patient-facing), CA-INDIRECT (clinical data), CA-PLANNED (roadmap only). Each tier has distinct graduated penalties.",
      "severity": "critical"
    },
    {
      "id": "INV-012",
      "label": "t4-pending-denominator-80",
      "statement": "T4 PENDING denominator is 80 (not 85). Stage 3 rubric normalized to /80 when T4 PENDING path is active.",
      "severity": "critical"
    },
    {
      "id": "INV-013",
      "label": "author-domain-context-zero-score",
      "statement": "Author domain context is informational only. Zero score impact. Domain background must not adjust, override, or reinterpret any score.",
      "severity": "critical"
    },
    {
      "id": "INV-014",
      "label": "derived-1-expiry-formula",
      "statement": "DERIVED-1: expiry_date = last_commit_date + 365 days. Formula is fixed.",
      "severity": "high"
    },
    {
      "id": "INV-015",
      "label": "derived-2-audit-branch",
      "statement": "DERIVED-2: audit_branch = branch at audit time. Must be recorded in audit metadata.",
      "severity": "high"
    },
    {
      "id": "INV-016",
      "label": "derived-3-before-stage3",
      "statement": "DERIVED-3 (trajectory_signal) must be computed BEFORE Stage 3 execution (Section 8.2 Step 5a). Computing it after Stage 3 is an ordering violation.",
      "severity": "critical"
    },
    {
      "id": "INV-017",
      "label": "governance-overlay-separation",
      "statement": "Stage 3G governance overlay is advisory only. Base tier is never modified by overlay score. G3=0 caps overlay verdict at WEAK regardless of other G scores.",
      "severity": "critical"
    },
    {
      "id": "INV-018",
      "label": "immutable-rules-require-minor-version",
      "statement": "IMMUTABLE rules require a minor version increment (1.x.0) to change. Patch versions (1.x.x) may not modify IMMUTABLE rules.",
      "severity": "critical"
    }
  ],
  "scope": {
    "include": [
      "stem_ai/",
      "scripts/",
      "docs/",
      "spec/",
      "discrimination/",
      "templates/",
      "references/",
      "memory/",
      "audits/benchmark-v1.4/",
      "SKILL.md",
      "README.md",
      "CHANGELOG.md",
      "pyproject.toml",
      "MANIFEST.in"
    ],
    "exclude": [
      ".git/",
      ".github/",
      "examples/",
      "*.sh",
      "node_modules/"
    ]
  },
  "source_kinds": {
    "canonical_spec": {
      "description": "Core rubric and execution specification",
      "default_tier": "memory",
      "trust_class": "canonical"
    },
    "discrimination_examples": {
      "description": "YES/NO calibration examples for scoring boundary cases",
      "default_tier": "artifact_ref",
      "trust_class": "canonical"
    },
    "reference_tables": {
      "description": "Lookup tables: tiers, triggers, taxonomy",
      "default_tier": "artifact_ref",
      "trust_class": "canonical"
    },
    "output_templates": {
      "description": "Institutional output templates",
      "default_tier": "artifact_ref",
      "trust_class": "canonical"
    }
  },
  "canonical_models": {
    "provenance": {
      "required": [
        "uri",
        "sha256",
        "kind",
        "created_at",
        "trust_class"
      ],
      "optional": [
        "note",
        "labels"
      ]
    },
    "context_item": {
      "required": [
        "id",
        "content",
        "tier",
        "trust_class"
      ],
      "optional": [
        "invoke_role",
        "score",
        "labels"
      ]
    },
    "context_budget": {
      "required": [
        "max_tokens",
        "used_tokens"
      ],
      "optional": []
    },
    "context_ledger_entry": {
      "required": [
        "session_id",
        "timestamp_utc",
        "context_hash"
      ],
      "optional": [
        "note"
      ]
    },
    "working_context": {
      "required": [
        "items",
        "budget"
      ],
      "optional": [
        "compiled_at"
      ]
    },
    "compiled_view": {
      "required": [
        "view_hash",
        "working_context"
      ],
      "optional": [
        "degraded",
        "target"
      ]
    }
  },
  "invoke_role_semantics": {
    "rule_type": "fixed_role_with_score_bonus",
    "note": "IMMUTABLE rubric items are anchor-pinned and never evicted from context.",
    "roles": {
      "none": {
        "meaning": "No special role",
        "score_bonus": 0.0,
        "pin_behavior": "unpinned",
        "compile_behavior": "include_if_budget_allows",
        "eviction_priority": 4
      },
      "hint": {
        "meaning": "Advisory context",
        "score_bonus": 0.1,
        "pin_behavior": "unpinned",
        "compile_behavior": "include_if_budget_allows",
        "eviction_priority": 3
      },
      "bridge": {
        "meaning": "Cross-component reference",
        "score_bonus": 0.2,
        "pin_behavior": "soft_pin",
        "compile_behavior": "prefer_include",
        "eviction_priority": 2
      },
      "anchor": {
        "meaning": "IMMUTABLE rule or SSOT — never evict",
        "score_bonus": 0.3,
        "pin_behavior": "pinned",
        "compile_behavior": "always_include",
        "eviction_priority": 1
      }
    }
  },
  "normalization_policy": {
    "preserve_verbatim_where_possible": true,
    "keep_category_order": [
      "design_invariants",
      "provenance_registry",
      "artifact_manifest",
      "deviation_log"
    ],
    "unknown_date_token": "UNKNOWN_DATE",
    "canonical_export_dedup": true,
    "whitespace_normalization": "strip_trailing_normalize_crlf_to_lf",
    "case_normalization_for_hashing": false,
    "structural_projection_is_canonical": true
  },
  "collector_pipeline": {
    "steps": [
      "collect",
      "normalize",
      "score",
      "dedup",
      "budget",
      "map",
      "handoff",
      "ledger"
    ],
    "source_priority": [
      "canonical",
      "distilled",
      "raw",
      "symbolic"
    ]
  },
  "scoring_policy": {
    "output_range": "[0, 1]",
    "one_shot_invoke_bonus": true,
    "one_shot_rule_text": "If a context item is the sole relevant item for the current task, its score receives the invoke bonus from its invoke_role.",
    "scoring_family": "weighted_sum_with_fail_closed_gates_v1",
    "function": {
      "kind": "weighted_sum_with_fail_closed_gates_v1",
      "aggregation": "weighted_sum",
      "component_order": [
        "sim",
        "recency",
        "invoke",
        "trust",
        "continuity"
      ],
      "equation": "score = sum_i(w_i * x_i), x_i in [0,1], weights normalized by sum, score clamped to [0,1]",
      "weight_normalization": "normalize_by_sum",
      "score_bounds": {
        "min": 0,
        "max": 1
      },
      "admission_rule": "exclude_if_any_gate_fails"
    },
    "weights": {
      "sim": 0.35,
      "recency": 0.15,
      "invoke": 0.2,
      "trust": 0.2,
      "continuity": 0.1
    },
    "components": {
      "sim": {
        "description": "Semantic similarity to current audit task",
        "preferred_metric": "cosine_similarity",
        "fallback_metric": "keyword_overlap",
        "normalization": "min_max"
      },
      "recency": {
        "description": "Recency decay based on last_modified",
        "function": "exponential_decay(lambda=0.1)",
        "unknown_date_recency": {
          "mode": "fixed",
          "value": 0.5,
          "rationale": "Unknown date treated as medium recency"
        }
      },
      "invoke": {
        "description": "invoke_role score bonus",
        "mapping": {
          "none": 0.0,
          "hint": 0.25,
          "bridge": 0.5,
          "anchor": 1.0
        }
      },
      "trust": {
        "description": "Trust class numeric value",
        "mapping": {
          "canonical": 1.0,
          "distilled": 0.75,
          "raw": 0.5,
          "symbolic": 0.25
        },
        "normalization": "direct"
      },
      "continuity": {
        "description": "Session continuity -- items used in prior turns score higher",
        "function": "linear_decay_from_last_use"
      }
    },
    "gate_policy": {
      "mode": "fail_closed",
      "min_similarity": 0.1,
      "min_trust": 0.25,
      "anchor_trust_floor": 0.75,
      "behavior_on_failure": "exclude_from_compiled_view"
    },
    "tie_breakers": [
      "invoke_role_priority",
      "recency",
      "trust_class"
    ]
  },
  "dedup_policy": {
    "compile_time_dedup": true,
    "exact_within_tier": {
      "enabled": true,
      "key": "content_hash"
    },
    "semantic_cross_tier": {
      "enabled": false,
      "threshold": 0.95,
      "action": "keep_higher_fidelity"
    },
    "fidelity_order": [
      "canonical",
      "distilled",
      "raw",
      "symbolic"
    ],
    "preserve_rules": [
      "never_dedup_anchor_items"
    ]
  },
  "budget_policy": {
    "max_tokens": 12000,
    "estimation_method": "character_count_div_4",
    "overflow_strategy": "evict_by_phase",
    "anchor_cap": 4000,
    "tier_priority": [
      "session",
      "memory",
      "artifact_ref",
      "working"
    ],
    "eviction_strategy": {
      "phase_1": {
        "description": "Evict working-tier items below score threshold",
        "order": [
          "working"
        ],
        "action": "evict_lowest_score_first",
        "guard": "do_not_evict_anchor"
      },
      "phase_2": {
        "description": "Evict artifact_ref items (discrimination examples, templates)",
        "order": [
          "artifact_ref"
        ],
        "action": "evict_lowest_score_first",
        "guard": "do_not_evict_anchor"
      },
      "phase_3": {
        "description": "Evict memory items",
        "order": [
          "memory"
        ],
        "action": "evict_lowest_score_first",
        "guard": "do_not_evict_anchor"
      },
      "phase_4": {
        "description": "Truncate non-anchor session items",
        "order": [
          "session"
        ],
        "action": "truncate_to_fit",
        "guard": "do_not_evict_anchor"
      },
      "phase_5": {
        "description": "Emergency: truncate anchor items -- mark as degraded",
        "order": [
          "session",
          "memory"
        ],
        "action": "truncate_anchors_mark_degraded",
        "guard": "none"
      }
    },
    "failure_condition": {
      "if_budget_still_exceeded": "emit_degraded_flag_and_proceed_with_partial_context"
    }
  },
  "mapping_rules": [
    {
      "source": "canonical_spec",
      "match": "spec/STEM-AI_v*.md",
      "to_context_item": {
        "tier": "memory",
        "invoke_role": "anchor",
        "trust_class": "canonical",
        "labels": [
          "canonical_spec",
          "immutable_rules"
        ]
      }
    },
    {
      "source": "discrimination_examples",
      "match": "discrimination/*.md",
      "to_context_item": {
        "tier": "artifact_ref",
        "invoke_role": "bridge",
        "trust_class": "canonical",
        "labels": [
          "discrimination"
        ]
      }
    },
    {
      "source": "reference_tables",
      "match": "references/*.md",
      "to_context_item": {
        "tier": "artifact_ref",
        "invoke_role": "hint",
        "trust_class": "canonical",
        "labels": [
          "reference"
        ]
      }
    }
  ],
  "handoff_policy": {
    "allowed_targets": [
      "ai_session"
    ],
    "max_context_depth": 3,
    "allow_memory": true,
    "allow_artifact_refs": true,
    "require_provenance": false,
    "redact": [
      "credentials",
      "secrets",
      "api_keys"
    ],
    "deny_patterns": [
      "*.env",
      "*.pem",
      "*.key"
    ],
    "memory_scope_rule": "session_only",
    "enforcement": {
      "prefilter": [
        "apply_redact_patterns",
        "check_deny_patterns"
      ],
      "target_compile": [
        "apply_budget"
      ],
      "output": {
        "view_hash": "sha256_of_compiled_view",
        "degraded_flag": false
      }
    }
  },
  "artifact_handle_policy": {
    "signed_handles": false,
    "signing_algorithm": "none",
    "expiry_required": false,
    "default_ttl_seconds": 3600,
    "inline_small_artifacts": {
      "enabled": true,
      "max_bytes": 4096
    },
    "signing_triggers": [],
    "handle_gap_policy": "warn_and_continue",
    "access_audit_required": false
  },
  "error_policy": {
    "parse_failure": {
      "action": "abort_and_report",
      "severity": "critical"
    },
    "provenance_resolution_failure": {
      "action": "warn_and_continue_with_degraded_flag",
      "severity": "warning"
    },
    "source_hash_mismatch": {
      "action": "warn_and_continue",
      "severity": "warning"
    },
    "dedup_failure": {
      "action": "warn_and_continue",
      "severity": "warning"
    },
    "scoring_failure": {
      "action": "use_fallback_score_zero",
      "severity": "error"
    },
    "budget_compile_failure": {
      "action": "emit_degraded_flag_and_truncate",
      "severity": "error"
    },
    "ledger_commit_failure": {
      "action": "warn_and_continue",
      "severity": "warning"
    },
    "target_policy_violation": {
      "action": "deny_handoff_report_violation",
      "severity": "critical"
    }
  },
  "ledger_policy": {
    "content_digest_only": true,
    "hash_chain": true,
    "payload_fields": [
      "session_id",
      "timestamp_utc",
      "context_hash",
      "item_count",
      "budget_used"
    ],
    "context_hash_formula": "sha256(project.version + sorted(provenance.sha256) + generated_at_utc)",
    "audit_chain": [
      "context_hash",
      "prior_entry_hash",
      "timestamp_utc"
    ]
  },
  "cache_policy": {
    "key_formula": "sha256(query_embedding + provenance_hashes + budget_max_tokens)",
    "fail_safe": "recompile_on_cache_miss",
    "note": "Cache is advisory only. A cache miss is not an error."
  },
  "schema_migration": {
    "versioning": "semver",
    "compatibility_rules": {
      "patch": "additive-only field additions, no removal, no semantic change",
      "minor": "new optional fields, deprecations, non-breaking semantic clarifications",
      "major": "breaking field changes, removal, scoring model changes"
    },
    "migration_strategy": [
      "validate existing archive against new schema",
      "apply additive fields with defaults",
      "run self_test_policy checks post-migration",
      "update mica_schema_version"
    ],
    "reproducibility_gate": {
      "required_match_rate": 1.0,
      "sample_scope": "all_required_fields"
    }
  },
  "observability": {
    "metrics": [
      "context_compile_ms",
      "budget_utilization",
      "degraded_rate",
      "handoff_leak_count",
      "audit_chain_integrity"
    ],
    "slo_hints": {
      "p95_context_compile_ms": 300,
      "p99_context_compile_ms": 600,
      "budget_failure_rate_max": 0.01,
      "degraded_rate_warn": 0.05,
      "degraded_rate_critical": 0.15,
      "handoff_leak_target": 0,
      "audit_link_integrity_target": 1.0
    }
  },
  "acceptance_criteria": [
    "Base final_score and T0-T4 tier remain deterministic for identical local input",
    "Score-affecting evidence is represented in evidence_ledger with stable POSIX finding_id values",
    "Stage 4 replication, AST summary, reasoning_model, and ai_advisory surfaces do not override final_score",
    "Provider advisory responses cite exact allowed_finding_ids and pass offline validation before use"
  ],
  "non_goals": [
    "Clinical safety, efficacy, regulatory, or scientific validity determination",
    "Provider API execution inside the core scanner",
    "Runtime execution of target repositories or model inference",
    "Individual author profiling or competitive intelligence"
  ],
