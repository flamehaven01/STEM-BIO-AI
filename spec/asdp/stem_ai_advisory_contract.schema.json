{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/flamehaven01/STEM-BIO-AI/spec/asdp/stem_ai_advisory_contract.schema.json",
  "title": "STEM BIO-AI Advisory Contract",
  "type": "object",
  "required": [
    "schema_version",
    "provider",
    "mode",
    "status",
    "input_contract",
    "reviewer_notes",
    "inspection_priorities",
    "citation_index",
    "invalid_citations",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "const": "stem-ai-advisory-v1.4"
    },
    "provider": {
      "type": "string"
    },
    "model": {
      "type": ["string", "null"]
    },
    "mode": {
      "type": "string"
    },
    "status": {
      "enum": ["not_run", "valid", "invalid", "error"]
    },
    "input_contract": {
      "type": "object",
      "required": ["schema_version", "finding_count", "omitted_finding_count", "sha256"],
      "properties": {
        "schema_version": {"const": "stem-ai-advisory-input-v1.4"},
        "finding_count": {"type": "integer", "minimum": 0},
        "omitted_finding_count": {"type": "integer", "minimum": 0},
        "sha256": {"type": "string", "pattern": "^[A-F0-9]{64}$"}
      },
      "additionalProperties": false
    },
    "reviewer_notes": {
      "type": "array",
      "items": {"$ref": "#/$defs/reviewer_note"}
    },
    "inspection_priorities": {
      "type": "array",
      "items": {"$ref": "#/$defs/inspection_priority"}
    },
    "citation_index": {
      "type": "object",
      "additionalProperties": {"type": "boolean"}
    },
    "invalid_citations": {
      "type": "array",
      "items": {"type": "string"}
    },
    "missing_citation_items": {
      "type": "array",
      "items": {"type": "string"}
    },
    "prohibited_claims": {
      "type": "array",
      "items": {"type": "string"}
    },
    "errors": {
      "type": "array",
      "items": {"type": "string"}
    },
    "policy": {
      "type": "object",
      "required": [
        "final_score_override",
        "requires_finding_id_citations",
        "raw_repo_text_allowed",
        "clinical_claims_allowed"
      ],
      "properties": {
        "final_score_override": {"const": false},
        "requires_finding_id_citations": {"const": true},
        "raw_repo_text_allowed": {"const": false},
        "clinical_claims_allowed": {"const": false}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "reviewer_note": {
      "type": "object",
      "required": ["claim", "severity", "cites", "recommended_action"],
      "properties": {
        "claim": {"type": "string"},
        "severity": {"enum": ["info", "warn", "block"]},
        "cites": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        },
        "recommended_action": {"type": "string"}
      },
      "additionalProperties": false
    },
    "inspection_priority": {
      "type": "object",
      "required": ["priority", "reason", "cites"],
      "properties": {
        "priority": {"enum": ["high", "medium", "low"]},
        "reason": {"type": "string"},
        "cites": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    }
  }
}
